{
  "name": "jdm-pro-server",
  "version": "1.0.0",
  "description": "JDM Pro backend — Bun monorepo (API + crawler worker)",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun apps/api/src/index.js",
    "dev": "bun --watch apps/api/src/index.js",
    "start:worker": "bun apps/worker/src/index.js",
    "dev:worker": "bun --watch apps/worker/src/index.js",
    "check": "bun test",
    "test": "bun test",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.js",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.js",
    "db:introspect": "drizzle-kit introspect --config packages/db/drizzle.config.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/lib-storage": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "bullmq": "5.78.0",
    "camelize": "^1.0.1",
    "cloakbrowser": "^0.3.26",
    "drizzle-orm": "0.45.2",
    "ioredis": "^5.11.1",
    "jsonapi-serializer": "3.6.9",
    "jsonwebtoken": "9.0.3",
    "linkedom": "0.18.12",
    "lodash": "^4.18.1",
    "openai": "6.42.0",
    "playwright-core": "^1.49.0",
    "postgres": "3.4.9",
    "sharp": "^0.35.1",
    "telegraf": "4.16.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "drizzle-kit": "0.31.10",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-prettier": "5.5.6",
    "prettier": "3.8.4"
  }
}
