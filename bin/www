#!/usr/bin/env node
require('dotenv').config();

// Memory monitoring and limits
const { createMemoryMonitor } = require('../server/utils/memory-monitor');

const app = require('../app');
const http = require('http');
const debug = require('debug')('www');
const server = http.createServer(app);
// const bot = require('../server/bot-app/index');

const port = process.env.PORT || 8080;

// Initialize memory monitor for main process
const memoryMonitor = createMemoryMonitor({
  maxHeapUsed: 400 * 1024 * 1024, // 400MB
  criticalHeapUsed: 450 * 1024 * 1024, // 450MB
  checkInterval: 2 * 60 * 1000, // Check every 2 minutes
  onCriticalMemory: memInfo => {
    const mb = bytes => Math.round((bytes / 1024 / 1024) * 100) / 100;
    console.error(`🚨 Critical memory in main process: ${mb(memInfo.heapUsed)}MB`);
    shutdown('Critical memory usage');
  },
});

// Start memory monitoring
memoryMonitor.start();

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  let bind = 'Port ' + port;

  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

server.listen(port, function () {
  if (process.env.NODE_ENV === 'production') {
    // bot.telegram.setWebhook(`${process.env.BACK_HOST_NAME}/api/webhook_telegram`);
    console.log('Webhook set for production.');
  }

  debug('Express server listening on port ' + server.address().port);

  // Log initial memory usage
  memoryMonitor.logMemoryUsage();

  // Periodic cleanup
  setInterval(
    async () => {
      try {
        await memoryMonitor.cleanupAllSessionInteractions();
        if (global.gc) {
          global.gc();
        }
      } catch (err) {
        debug('Error during periodic cleanup:', err);
      }
    },
    5 * 60 * 1000
  ); // Every 5 minutes
});

server.on('error', onError);

// Enable graceful stop
const shutdown = async val => {
  console.log('Shutting down gracefully...');

  try {
    // Stop memory monitor
    if (memoryMonitor) {
      memoryMonitor.stop();
    }

    console.log('Webhook deregistered and bot shutdown gracefully.');
    server.close(() => {
      process.exit(0);
    });
  } catch (error) {
    console.error('Error during shutdown:', error);
    process.exit(1);
  }
};

// Handle memory pressure warnings
process.on('warning', warning => {
  if (
    warning.name === 'MaxListenersExceededWarning' ||
    warning.message?.includes('memory') ||
    warning.message?.includes('heap')
  ) {
    console.warn('Memory warning:', warning.message);
    memoryMonitor.forceGarbageCollection();
  }
});

process.on('SIGINT', () => shutdown('SIGINT'));
process.on('SIGTERM', () => shutdown('SIGTERM'));

console.log(`Listening on port: ${port}`);
